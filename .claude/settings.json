{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
      "allow": [
        "Bash(git status)",
        "Bash(git diff *)",
        "Bash(php -l *)",
        "Bash(composer install)",
        "Bash(composer test)",
        "Bash(vendor/bin/phpunit *)"
      ],
      "deny": [
        "Read(./.env)",
        "Read(./.env.*)",
        "Read(./secrets/**)",
        "Read(./storage/backup/**)",
        "Bash(curl *)",
        "Bash(wget *)"
      ]
    }
  }